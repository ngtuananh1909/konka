# Review Server Configuration
# Provider: 'google' (default, uses Google Gemini) or 'openrouter' (uses OpenRouter API)
REVIEW_PROVIDER=openrouter

# API Key for the chosen provider
# For Google: use your Gemini API key from https://aistudio.google.com
# For OpenRouter: use your OpenRouter key from https://openrouter.ai/keys
REVIEW_PROVIDER_API_KEY=

# Model selection (provider-specific)
# Google models: 'gemini-2.5-pro' (default), 'gemini-1.5-pro', 'gemini-1.5-flash'
# OpenRouter models: 'mistral-1' (default, ~cheapest), 'openai/gpt-4-turbo', 'anthropic/claude-3-opus'
REVIEW_PROVIDER_MODEL=mistral-1

# Token optimization: limit max output tokens to reduce costs
# Recommended: 256-512 (JSON response is typically 100-300 tokens)
REVIEW_PROVIDER_MAX_TOKENS=512

# OpenRouter custom endpoint (rarely needed)
# REVIEW_PROVIDER_URL=https://api.openrouter.ai/v1/chat/completions

# Server host/port
REVIEW_SERVER_HOST=127.0.0.1
REVIEW_SERVER_PORT=8787

# Legacy: For backward compatibility, can still use GEMINI_API_KEY
# This will be used as REVIEW_PROVIDER_API_KEY if that is not set
# GEMINI_API_KEY=
